<div class="animate-in" style="text-align: center; padding: 4rem 2rem;">
    <div
        style="width: 100px; height: 100px; background: rgba(239,83,80,0.15); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 2rem; border: 2px solid rgba(239,83,80,0.3);">
        <i class="fas fa-exclamation-triangle" style="font-size: 2.5rem; color: var(--accent-danger);"></i>
    </div>
    <h2 style="font-size: 2rem; margin-bottom: 1rem;">Đã có lỗi xảy ra!</h2>
    <p style="color: var(--text-secondary); font-size: 1.1rem; margin-bottom: 0.5rem;">{{message}}</p>
    {{#if error}}
    <p style="color: var(--text-muted); font-size: 0.9rem; margin-bottom: 2rem;">{{error}}</p>
    {{/if}}
    <a href="/" class="btn btn-primary"><i class="fas fa-home"></i> Về trang chủ</a>
</div>